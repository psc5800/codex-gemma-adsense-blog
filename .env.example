# Copy to .env and edit values before publishing.
BLOG_TITLE="Codex Gemma AdSense Blog"
BLOG_DESCRIPTION="A low-cost static blog pipeline powered by local Gemma 4 drafts and Codex review."
BLOG_URL="https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPOSITORY"
AUTHOR_NAME="Your Name"
LANGUAGE="ko"

# Local Ollama instance started by scripts/start-ollama-f.ps1
OLLAMA_BASE_URL="http://127.0.0.1:11435"
OLLAMA_MODEL="gemma4:e2b"

# Keep false until Google AdSense approval is granted.
ADSENSE_ENABLED="false"
ADSENSE_CLIENT=""

# Optional verification tokens.
GOOGLE_SITE_VERIFICATION=""
NAVER_SITE_VERIFICATION=""
